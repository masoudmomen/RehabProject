@page "/Privacy-Policy"
@* @rendermode InteractiveServer *@
@inject IJSRuntime jSRuntime
@using Microsoft.AspNetCore.Components.Web
@using Rehab.EndPoint.Web.Components.Common

@using Rehab.Application.Seo
@inject ISeoService SeoService


<HeadContent>
    <meta name="keywords" content="@Keywords" />
    <meta name="description" content="@Description" />
</HeadContent>

<Seo Title="Privacy Policy - Rehab Navigator"
     Description="Learn about Rehab's commitment to protecting your privacy and the measures we take to ensure your data is safe."
     CanonicalUrl="https://www.rehabnavigator.com/privacy-policy"
     FaviconUrl="favicon.png" />
 
 
<!-- Page wrapper -->
<main class="container" style="max-width:1140px; padding: 40px 20px 80px;">

    <!-- Hero -->
    <div class="hero-pp mb-4 position-relative">
        <span class="hero-eyebrow">
            <i class="bi bi-shield-lock-fill me-1"></i> RehabNavigator Privacy Policy
        </span>
        <h1>Your Privacy and Information Choices</h1>
        <p>
            This Privacy Policy explains how RehabNavigator may collect, use, share, store, and protect
            information when people use our website, directory features, facility profiles, contact forms,
            provider listing tools, advertising pages, and related services.
        </p>
    </div>

    <!-- Important notice -->
    <div class="notice-important p-4 mb-4 d-flex gap-3 align-items-start">
        <i class="bi bi-exclamation-circle-fill fs-5 mt-1" style="color:var(--purple)"></i>
        <p class="mb-0">
            <strong>Important:</strong>
            RehabNavigator is an online directory and information platform. We are not a treatment provider,
            medical provider, insurance company, referral service, admissions service, or emergency service.
            Users can browse RehabNavigator without submitting detailed medical information.
        </p>
    </div>

    <!-- Content grid -->
    <div class="row g-4 align-items-start">

        <!-- Sidebar -->
        <div class="col-lg-3 d-none d-lg-block">
            <div class="sidebar-pp">
                <div class="sidebar-title"><i class="bi bi-list-ul me-1"></i> On This Page</div>
                <nav class="sidebar-nav nav flex-column">
                    <a class="nav-link" href="#overview"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Overview</a>
                    <a class="nav-link" href="#privacy-notice"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Important Notice</a>
                    <a class="nav-link" href="#information"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Information We Collect</a>
                    <a class="nav-link" href="#usage"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>How We Use It</a>
                    <a class="nav-link" href="#sharing"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Information Sharing</a>
                    <a class="nav-link" href="#providers"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>External Providers</a>
                    <a class="nav-link" href="#tracking"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Cookies &amp; Analytics</a>
                    <a class="nav-link" href="#sponsored"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Sponsored Listings</a>
                    <a class="nav-link" href="#sensitive"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Info Not to Submit</a>
                    <a class="nav-link" href="#choices"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Your Choices</a>
                    <a class="nav-link" href="#rights"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Privacy Requests</a>
                    <a class="nav-link" href="#security"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Data Security</a>
                    <a class="nav-link" href="#retention"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Data Retention</a>
                    <a class="nav-link" href="#children"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Children's Privacy</a>
                    <a class="nav-link" href="#international"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>International Users</a>
                    <a class="nav-link" href="#changes"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Policy Updates</a>
                    <a class="nav-link" href="#contact"><i class="bi bi-circle-fill" style="font-size:.45rem; opacity:.5"></i>Contact Information</a>
                </nav>
            </div>
        </div>

        <!-- Main content -->
        <div class="col-lg-9">
            <div class="d-flex flex-column gap-3">

                <!-- Overview -->
                <section class="section-card" id="overview">
                    <span class="section-badge"><i class="bi bi-info-circle-fill"></i> Overview</span>
                    <h2>About This Privacy Policy</h2>
                    <p>RehabNavigator provides directory information, facility profiles, search tools, educational content, and provider visibility options related to drug and alcohol rehab centers, mental health providers, behavioral health facilities, and recovery resources.</p>
                    <p>This Privacy Policy applies to website visitors, individuals and families using the directory, treatment providers, facility representatives, advertisers, and anyone who submits information through RehabNavigator.</p>
                    <p class="mb-0">The information we collect depends on how a user interacts with the website. Some users may only browse the website. Others may submit a contact form, request a listing update, claim a facility profile, ask about advertising, or use future features that may be added to the platform.</p>
                </section>

                <!-- Important Notice -->
                <section class="section-card" id="privacy-notice">
                    <span class="section-badge"><i class="bi bi-exclamation-triangle-fill"></i> Important Notice</span>
                    <h2>Do Not Submit Emergency or Detailed Medical Information Through General Forms</h2>
                    <p>RehabNavigator is designed to help users search and review facility information. General website forms should not be used to submit medical records, diagnosis details, treatment history, substance use history, mental health history, insurance claim documents, payment card details, Social Security numbers, or emergency information.</p>
                    <div class="warning-box">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        If someone is in immediate danger, experiencing a medical emergency, or needs urgent crisis support, contact local emergency services or an official crisis resource in your area right away.
                    </div>
                </section>

                <!-- Information We Collect -->
                <section class="section-card" id="information">
                    <span class="section-badge"><i class="bi bi-database-fill"></i> Information Collection</span>
                    <h2>Information We May Collect</h2>
                    <p>RehabNavigator may collect information directly from users, automatically through website technology, or from treatment providers and facility representatives.</p>
                    <h3>Information You Submit</h3>
                    <ul>
                        <li>Name, email address, phone number, and message content</li>
                        <li>General contact inquiries or website feedback</li>
                        <li>Facility name or provider-related information submitted through forms</li>
                        <li>Listing update requests, claim profile requests, or new listing requests</li>
                        <li>Advertising inquiries, Plans &amp; Pricing inquiries, or provider visibility requests</li>
                        <li>Other information voluntarily submitted through website forms or communications</li>
                    </ul>
                    <h3>Website and Usage Information</h3>
                    <ul>
                        <li>Pages visited, search activity, filters used, and facility profiles viewed</li>
                        <li>Clicked links, website navigation patterns, and general usage activity</li>
                        <li>Browser type, device type, operating system, IP address, and approximate location information</li>
                        <li>Analytics, cookie, pixel, session, or similar technical information if those tools are used</li>
                    </ul>
                    <h3>Provider and Facility Information</h3>
                    <ul>
                        <li>Facility name, address, phone number, website link, and general contact details</li>
                        <li>Conditions treated, levels of care, treatments offered, insurance information, amenities, accreditations, photos, and facility highlights</li>
                        <li>Information submitted by treatment providers, facility representatives, advertisers, or public sources</li>
                        <li>Business contact information for provider representatives or listing contacts</li>
                    </ul>
                    <div class="soft-box mt-3">
                        <i class="bi bi-info-circle me-2"></i>
                        Users are not required to submit detailed health information to browse RehabNavigator.
                    </div>
                </section>

                <!-- How We Use It -->
                <section class="section-card" id="usage">
                    <span class="section-badge"><i class="bi bi-gear-fill"></i> Use of Information</span>
                    <h2>How Information May Be Used</h2>
                    <p>RehabNavigator may use information for website operations, user support, directory management, provider communications, and platform improvement.</p>
                    <ul>
                        <li>Respond to user inquiries, contact requests, or support messages</li>
                        <li>Operate, maintain, secure, and improve the website</li>
                        <li>Support search tools, facility profiles, listing pages, and directory features</li>
                        <li>Process provider listing requests, claim profile requests, and facility update requests</li>
                        <li>Respond to advertising, featured placement, and Plans &amp; Pricing inquiries</li>
                        <li>Analyze website performance, traffic, usability, and feature engagement</li>
                        <li>Detect, prevent, and respond to fraud, abuse, technical issues, or security risks</li>
                        <li>Communicate with users or providers about requests they submit</li>
                        <li>Comply with legal obligations, enforce policies, and protect rights</li>
                    </ul>
                    <p class="mb-0 fw-semibold" style="color:var(--navy)">We do not sell personal information to third-party data brokers.</p>
                </section>

                <!-- Information Sharing -->
                <section class="section-card" id="sharing">
                    <span class="section-badge"><i class="bi bi-share-fill"></i> Information Sharing</span>
                    <h2>How Information May Be Shared</h2>
                    <p>RehabNavigator may share information only as reasonably necessary for website operation, service support, analytics, security, legal compliance, or other business purposes described in this Privacy Policy.</p>
                    <h3>Service Providers and Vendors</h3>
                    <p>We may share information with vendors that help operate the website, such as hosting providers, form tools, email services, analytics providers, security vendors, customer support tools, CRM systems, advertising measurement tools, or other service providers.</p>
                    <h3>Advertising and Analytics Partners</h3>
                    <p>If analytics, cookies, pixels, conversion tracking, call tracking, retargeting, or similar technologies are used, certain website activity or technical information may be shared with analytics or advertising partners for measurement, performance, fraud prevention, or advertising-related purposes.</p>
                    <h3>Legal, Safety, and Compliance Reasons</h3>
                    <p>We may disclose information if required by law, legal process, court order, regulatory request, or when reasonably necessary to protect safety, prevent fraud, enforce policies, respond to security issues, or protect the rights of RehabNavigator, users, providers, or others.</p>
                    <h3>Business Transfers</h3>
                    <p>Information may be transferred or reviewed as part of a merger, acquisition, financing, reorganization, sale of assets, or similar business transaction involving RehabNavigator.</p>
                    <div class="soft-box mt-3">
                        <i class="bi bi-info-circle me-2"></i>
                        RehabNavigator does not share a user's personal contact information with treatment providers based only on searches, filters, page views, or facility profile activity.
                    </div>
                </section>

                <!-- External Providers -->
                <section class="section-card" id="providers">
                    <span class="section-badge"><i class="bi bi-link-45deg"></i> External Provider Links</span>
                    <h2>Treatment Providers and External Contact Options</h2>
                    <p>RehabNavigator may display facility phone numbers, website links, and other provider contact information within facility profiles.</p>
                    <p>When a user chooses to call a provider, visit a provider's website, or contact a provider outside RehabNavigator, any information the user shares is provided directly to that provider and is subject to that provider's own privacy practices.</p>
                    <p class="mb-0">RehabNavigator does not control how external providers, third-party websites, phone systems, or linked services collect, use, store, or protect information. Users should review the privacy practices of any provider or external website they contact directly.</p>
                </section>

                <!-- Cookies & Analytics -->
                <section class="section-card" id="tracking">
                    <span class="section-badge"><i class="bi bi-cookie"></i> Technology</span>
                    <h2>Cookies, Analytics, and Advertising Technologies</h2>
                    <p>RehabNavigator may use cookies, pixels, analytics tools, session tracking, conversion tracking, call tracking, form tracking, retargeting, or similar technologies depending on the features and tools active on the website.</p>
                    <p>These technologies may help us understand:</p>
                    <ul>
                        <li>Website traffic, page views, and user navigation patterns</li>
                        <li>Search behavior, filter usage, and facility profile engagement</li>
                        <li>Website performance, errors, and usability improvements</li>
                        <li>Advertising performance, referral sources, and conversion activity</li>
                        <li>Security, fraud prevention, and technical reliability</li>
                    </ul>
                    <p class="mb-0">Users may be able to manage cookies through browser settings, device settings, or available opt-out tools. Disabling cookies may affect how some website features work.</p>
                </section>

                <!-- Sponsored Listings -->
                <section class="section-card" id="sponsored">
                    <span class="section-badge"><i class="bi bi-star-fill"></i> Sponsored Visibility</span>
                    <h2>Advertising and Sponsored Listings</h2>
                    <p>Some facilities or providers may pay for advertising, enhanced visibility, featured placement, sponsored listings, or other provider visibility options on RehabNavigator.</p>
                    <p>Sponsored placement is intended to improve visibility within the directory. It should not be interpreted as a clinical endorsement, medical recommendation, treatment recommendation, ranking of care quality, or guarantee of results.</p>
                    <p class="mb-0">Users should review facility information, contact providers directly, confirm important details, and consult qualified professionals when appropriate.</p>
                </section>

                <!-- Info You Should Not Submit -->
                <section class="section-card" id="sensitive">
                    <span class="section-badge"><i class="bi bi-shield-exclamation"></i> Information Limits</span>
                    <h2>Information You Should Not Submit</h2>
                    <p>RehabNavigator currently provides directory information, search tools, facility profiles, educational content, general contact options, and provider-related inquiry forms.</p>
                    <p>Users do not need to submit medical records or detailed health information to browse RehabNavigator or review facility profiles.</p>
                    <p>Please do not submit medical records, diagnosis details, treatment history, substance use history, mental health history, insurance claim documents, Social Security numbers, payment card details, or emergency information through general website forms.</p>
                    <p class="mb-0">RehabNavigator is not a medical intake system, patient portal, treatment provider, insurance provider, referral service, admissions service, or emergency service.</p>
                </section>

                <!-- Your Choices -->
                <section class="section-card" id="choices">
                    <span class="section-badge"><i class="bi bi-sliders"></i> User Control</span>
                    <h2>Your Privacy Choices</h2>
                    <p>Users may control certain information and communications in the following ways:</p>
                    <ul>
                        <li>Choose not to submit optional information through website forms</li>
                        <li>Avoid submitting sensitive health or emergency information through general forms</li>
                        <li>Manage cookies through browser or device settings</li>
                        <li>Use available opt-out tools for certain analytics or advertising technologies, where offered</li>
                        <li>Request to stop receiving certain marketing or promotional communications</li>
                        <li>Contact RehabNavigator with privacy-related questions or requests</li>
                    </ul>
                    <p class="mb-0">Transactional, service-related, or legally required communications may still be sent when necessary.</p>
                </section>

                <!-- Privacy Requests -->
                <section class="section-card" id="rights">
                    <span class="section-badge"><i class="bi bi-person-check-fill"></i> Privacy Requests</span>
                    <h2>Privacy Choices and Requests</h2>
                    <p>You may contact RehabNavigator to ask about personal information you have submitted through our website, such as a Contact Us message, provider listing request, claim request, listing update request, advertising inquiry, or Plans &amp; Pricing inquiry.</p>
                    <p>Depending on the type of information involved and applicable law, you may request that we review, correct, update, or stop using information you submitted to us.</p>
                    <p>You can also manage cookies through your browser settings and may request to stop receiving non-essential marketing or promotional communications from RehabNavigator.</p>
                    <p class="mb-0">For privacy and security protection, we may need to verify a request before making changes or sharing information about any records associated with you.</p>
                </section>

                <!-- Data Security -->
                <section class="section-card" id="security">
                    <span class="section-badge"><i class="bi bi-lock-fill"></i> Protection Measures</span>
                    <h2>Data Security</h2>
                    <p>RehabNavigator uses reasonable administrative, technical, and organizational safeguards intended to help protect information submitted through the website.</p>
                    <p class="mb-0">No internet transmission, website, email system, form tool, or electronic storage system can be guaranteed to be completely secure. Users should avoid submitting highly sensitive information through general website forms.</p>
                </section>

                <!-- Data Retention -->
                <section class="section-card" id="retention">
                    <span class="section-badge"><i class="bi bi-clock-fill"></i> Storage Periods</span>
                    <h2>Data Retention</h2>
                    <p>RehabNavigator may retain information for as long as reasonably necessary to operate the website, respond to inquiries, maintain business records, support provider listings, improve services, maintain security, comply with legal obligations, resolve disputes, and enforce policies.</p>
                    <p class="mb-0">Retention periods may vary based on the type of information, the reason it was collected, legal requirements, and operational needs.</p>
                </section>

                <!-- Children's Privacy -->
                <section class="section-card" id="children">
                    <span class="section-badge"><i class="bi bi-people-fill"></i> Age of Use</span>
                    <h2>Children's Privacy</h2>
                    <p>RehabNavigator is not directed to children under the age of 13, and we do not knowingly request personal information from children under 13.</p>
                    <p class="mb-0">General website forms, including the Contact Us form, are intended for adults and authorized representatives.</p>
                </section>

                <!-- International Users -->
                <section class="section-card" id="international">
                    <span class="section-badge"><i class="bi bi-globe"></i> International Access</span>
                    <h2>International Users</h2>
                    <p>RehabNavigator may be accessed from different locations. If users access the website from outside the United States, they understand that information may be processed, transferred, or stored in the United States or other jurisdictions where our service providers operate.</p>
                    <p class="mb-0">Privacy laws may differ depending on the user's location. RehabNavigator will handle privacy requests as required by applicable law.</p>
                </section>

                <!-- Policy Updates -->
                <section class="section-card" id="changes">
                    <span class="section-badge"><i class="bi bi-arrow-repeat"></i> Policy Updates</span>
                    <h2>Changes to This Privacy Policy</h2>
                    <p>RehabNavigator may update this Privacy Policy periodically to reflect changes in website features, data practices, legal requirements, or business operations.</p>
                    <p class="mb-0">Updated versions will be posted on this page with a revised effective date. Continued use of the website after an update means the user has access to the updated Privacy Policy.</p>
                </section>

                <!-- Contact -->
                <section class="section-card" id="contact">
                    <span class="section-badge"><i class="bi bi-envelope-fill"></i> Contact Us</span>
                    <h2>Questions About Privacy</h2>
                    <p>If you have questions about this Privacy Policy, privacy choices, or privacy-related requests, please contact RehabNavigator through the official Contact Us page.</p>
                    <p class="mb-0 text-muted" style="font-size:.875rem">Last updated: May 2026</p>
                </section>

            </div><!-- /flex column -->
        </div><!-- /col-lg-9 -->
    </div><!-- /row -->
</main>


@code {
    private string? Keywords;
    private string? Description;
    private void LoadMeta()
    {
        var Meta = SeoService.GetMeta("PrivacyPolicy");

        if (Meta != null)
        {
            if (Meta.Keywords != null)
                Keywords = string.Join(",", Meta.Keywords);

            Description = Meta.Description;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        LoadMeta();
    }
}
