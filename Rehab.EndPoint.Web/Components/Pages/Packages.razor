@page "/packages"
@using Rehab.EndPoint.Web.Components.Common
@using Rehab.EndPoint.Web.ViewModels
@rendermode InteractiveServer

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, sans-serif; background:#f6f9fc; color:#173247; line-height:1.6; }
    .page { max-width:1180px; margin:0 auto; padding:64px 20px; }
    .hero1 { text-align:center; margin-bottom:38px; }
    .eyebrow { color:#2c7a9b; font-weight:700; font-size:13px; letter-spacing:.08em; text-transform:uppercase; }
    .hero1 h1 { font-size:42px; line-height:1.15; margin:10px 0 14px; }
    .hero1 p { max-width:760px; margin:0 auto; color:#607080; font-size:17px; }
    .claim-panel { background:#fff; border:1px solid #dce6ef; border-radius:26px; padding:34px; box-shadow:0 12px 34px rgba(18,48,74,.06); margin-bottom:34px; text-align:center; }
    .claim-panel h2 { font-size:30px; margin-bottom:10px; }
    .claim-panel h2 span { color:#2c7a9b; }
    .claim-panel p { color:#607080; margin-bottom:22px; }
    .search-box { max-width:560px; margin:0 auto; display:flex; border:1px solid #b9d3e2; border-radius:14px; overflow:hidden; background:#fff; }
    .search-box input { flex:1; border:none; padding:16px; font-size:15px; outline:none; }
    .search-box button { border:none; background:#2c7a9b; color:#fff; padding:0 22px; font-weight:700; cursor:pointer; }
    .dynamic-strip { background:#eef3f7; border-radius:22px; padding:28px; margin-bottom:34px; text-align:center; border:1px solid #dce6ef; }
    .dynamic-strip h2 { font-size:28px; margin-bottom:8px; }
    .dynamic-strip h2 span { color:#2c7a9b; }
    .dynamic-strip p { color:#607080; max-width:740px; margin:0 auto; }
    .pricing-layout { margin-bottom:34px; }
    .pricing-cards { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; align-items:stretch; }
    .card { background:#fff; border:1px solid #dce6ef; border-radius:22px; padding:30px; box-shadow:0 10px 28px rgba(18,48,74,.06); position:relative; display:flex; flex-direction:column; }
    .card.featured { border:2px solid #2c7a9b; }
    .badge { position:absolute; top:18px; right:18px; background:#eaf6fb; color:#2c7a9b; padding:6px 10px; border-radius:999px; font-size:12px; font-weight:700; }
    .card h3 { font-size:26px; margin-bottom:4px; }
    .card.basic-card h3, .card.basic-card .subtitle, .card.basic-card .price, .card.basic-card .price-note { text-align:center; }
    .subtitle { color:#748494; margin-bottom:20px; }
    .price { font-size:30px; font-weight:800; margin-bottom:10px; }
    .price-note { color:#607080; font-size:14px; margin-bottom:20px; }
    .simple-list { list-style:none; margin-bottom:24px; }
    .simple-list li { padding:8px 0; border-bottom:1px solid #edf1f5; color:#334b5e; }
    .simple-list li:last-child { border-bottom:none; }
    /* .btn { display:block; width:100%; text-align:center; text-decoration:none; padding:13px 16px; border-radius:12px; font-weight:700; margin-top:auto; }
    .btn-primary { background:#2c7a9b; color:#fff; } */
    .btn-secondary { background:#eef4f8; color:#173247; }
    .fit-section { display:grid; grid-template-columns:repeat(2,1fr); gap:22px; margin:34px 0; }
    .fit-box { background:#fff; border:1px solid #dce6ef; border-radius:20px; padding:26px; }
    .fit-box h3 { font-size:22px; margin-bottom:10px; }
    .fit-box p { color:#607080; }
    .comparison-table { background:#fff; border-radius:20px; overflow:hidden; border:1px solid #dce6ef; margin-bottom:34px; }
    table { width:100%; border-collapse:collapse; }
    th, td { padding:18px 20px; text-align:center; border-bottom:1px solid #edf1f5; }
    th { background:#eaf1f8; color:#173247; }
    th:first-child, td:first-child { text-align:left; }
    td { color:#334b5e; }
    .check { font-weight:800; color:#173247; }
    .dash { color:#7d8a94; }
    .contact-section { background:#173247; color:#fff; border-radius:28px; padding:36px; display:grid; grid-template-columns:1fr 1.2fr; gap:34px; align-items:start; }
    .contact-copy h2 { font-size:30px; margin-bottom:12px; }
    .contact-copy p, .contact-copy ul { color:#d8e5ee; }
    .contact-copy ul { padding-left:18px; margin-top:18px; }
    .contact-form { background:#fff; border-radius:22px; padding:24px; color:#173247; }
    .form-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; }
    label { font-size:13px; font-weight:700; margin-bottom:5px; display:block; }
    input, select, textarea { width:100%; border:1px solid #cfdce6; border-radius:10px; padding:12px; font-size:14px; font-family:Arial,sans-serif; }
    textarea { min-height:86px; resize:vertical; }
    .full { grid-column:1 / -1; }
    .submit-btn { margin-top:16px; border:none; background:#2c7a9b; color:#fff; padding:14px; width:100%; border-radius:12px; font-weight:800; cursor:pointer; font-size:15px; }
    
  </style>



