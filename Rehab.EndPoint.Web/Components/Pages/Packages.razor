        <tr><td>Enhanced Profile Detail &amp; Presentation</td><td class="dash">—</td><td class="check">✓</td><td class="check">✓</td></tr>
        <tr><td>Full Profile Detail &amp; Presentation</td><td class="dash">—</td><td class="dash">—</td><td class="check">✓</td></tr>
        <tr><td>Homepage / Top Search Placement</td><td class="dash">—</td><td class="dash">—</td><td class="check">✓</td></tr>
        <tr><td>Popular Centers Section</td><td class="dash">—</td><td class="dash">—</td><td class="check">✓</td></tr>
        <tr><td>Nearby Facilities Modal</td><td class="dash">—</td><td class="dash">—</td><td class="check">✓</td></tr>
        <tr><td>Blog / Content Promotion</td><td class="dash">—</td><td class="dash">—</td><td class="check">✓</td></tr>
      </tbody></table>
    </section>


</main>


<PackagesModalComponent 
    Visible="@showModal"
    VisibleChanged="v => showModal = v"
    PackageName="@selectedPackage"
    PackagePrice="@selectedPrice"
    />


@code {
    private bool showModal = false;
    private string selectedPackage;
    private string selectedPrice;

    void OpenModal(string package,string price)
    {
        selectedPackage = package;
        selectedPrice = price;
        showModal = true;
    }

    private async Task HandleSubmit(PackageRequestViewModel model)
    {
    }
  
}
<style>
    .hero-title {
        font-size: 2rem;
        font-weight: 500;
        color: #1a1a1a;
    }

    .hero-sub {
        font-size: 1rem;
        color: #6b6b6b;
    }

    /* ── Cards ── */
    .pkg-card {
        background: #ffffff;
        border: 1px solid #e0dfd8;
        border-radius: 14px;
        display: flex;
        flex-direction: column;
        height: 100%;
        position: relative;
    }

        .pkg-card.featured {
            border: 2px solid #7F77DD;
        }

    .pkg-name {
        font-size: 1.1rem;
        font-weight: 500;
    }

    .pkg-sub {
        font-size: 0.78rem;
        color: #6b6b6b;
    }

    .price-from {
        font-size: 0.65rem;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .price-val {
        font-size: 1.75rem;
        font-weight: 500;
        line-height: 1.2;
    }

    .price-range {
        font-size: 1rem;
        font-weight: 400;
        color: #6b6b6b;
    }

    .price-period {
        font-size: 0.75rem;
        color: #6b6b6b;
    }

    .section-label {
        font-size: 0.65rem;
        font-weight: 600;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.07em;
    }

    .feature-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

        .feature-list li {
            font-size: 0.78rem;
            color: #555;
            display: flex;
            align-items: flex-start;
            gap: 8px;
            line-height: 1.4;
        }

    .check-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .check-icon {
        color: #fff;
        font-size: 7px;
        line-height: 1;
    }

    .check-gray {
        background: #B4B2A9;
    }

    .check-teal {
        background: #5DCAA5;
    }

    .check-purple {
        background: #7F77DD;
    }

    /* ── Popular badge ── */
    .popular-badge {
        position: absolute;
        top: -13px;
        left: 50%;
        transform: translateX(-50%);
        white-space: nowrap;
        background: #EEEDFE;
        color: #3C3489;
        font-size: 0.7rem;
        font-weight: 500;
        padding: 3px 12px;
        border-radius: 6px;
    }

    /* ── CTA buttons ── */
    .btn-pkg {
        border: 1px solid #ccc;
        background: transparent;
        color: #1a1a1a;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        padding: 9px;
        width: 100%;
        transition: background 0.15s;
    }

        .btn-pkg:hover {
            background: #f3f3f3;
        }

    .btn-pkg-primary {
        background: #534AB7;
        color: #EEEDFE;
        border: none;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        padding: 9px;
        width: 100%;
        transition: background 0.15s;
    }

        .btn-pkg-primary:hover {
            background: #7F77DD;
            color: #fff;
        }

    /* ── Footer note ── */
    .footer-note {
        font-size: 0.72rem;
        color: #bbb;
    }

    /* ── Modal ── */
   
</style>
 