@page "/packages"
@using Rehab.EndPoint.Web.Components.Common
@using Rehab.EndPoint.Web.ViewModels
@rendermode InteractiveServer

<style>

</style>

<section class="billing-toggle-wrap" aria-label="Billing options">

    <div class="billing-toggle">
        <input type="radio" id="billing-annual" name="billing" value="annual"
               checked="@(billingType == "Annually")"
               @onchange="@(() => OnBillingChanged("Annually"))" />
        <label for="billing-annual">Pay annually</label>

        <input type="radio" id="billing-monthly" name="billing" value="monthly"
               checked="@(billingType == "Monthly")"
               @onchange="@(() => OnBillingChanged("Monthly"))" />
        <label for="billing-monthly">Pay Monthly</label>
    </div>

</section>
<div class="text-center">
    <h2>Plans & Pricing </h2>
    @if (billingType == "Annually")
    {
        <p>
            Reduced monthly rate with a one-year commitment. All plans are billed monthly.
        </p>
    }
    else if (billingType == "Monthly")
    {
        <p>
            Flexible month-to-month billing. All plans are billed monthly.

        </p>
    }

</div>

<section class="packages mt-5">
    <!-- Pricing Cards -->
    <div class="container pb-2 px-4">

        <div class="row g-4">

            <!-- Free -->
            <div class="col-12 col-md-3">
                <div class="pkg-card p-4">
                    <p class="pkg-name mb-1">Free</p>

                    <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                    <p class="price-val mb-0">$0</p>
                    <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">

                    <ul class="feature-list mb-3">
                        <li><span class="check-dot check-gray"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Essential Listing</li>
                        <li><span class="check-dot check-gray"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Minimal Visibility</li>

                    </ul>

                    <div class="mt-auto">
                        <button class="btn-pkg" @onclick='@(() => OpenModal("Free", "$0"))'>
                            Claim Profile
                        </button>
                    </div>
                </div>
            </div>
            <!-- Essential -->
            <div class="col-12 col-md-3">
                <div class="pkg-card p-4">
                    <p class="pkg-name mb-1">Essential</p>
                    <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                    <div class="price-val mb-0" data-monthly="$399" data-annually="$499">
                        @if (billingType == "Annually")
                        {
                            @basicannuallyPrice
                        }
                        else if (billingType == "Monthly")
                        {
                            @basicMonthlyPrice
                        }
                        <span>
                            /Month
                        </span>
                    </div>
                    <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                    <ul class="feature-list mb-3">
                        <li><span class="check-dot check-gray"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Up to 10 Qualified Profile Views / Day</li>
                        <li><span class="check-dot check-gray"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Up to 300 Impressions / Day</li>

                    </ul>

                    <div class="mt-auto">
                        <button class="btn-pkg" @onclick='@(() => OpenModal("Essential", "?????"))'>
                            Get Started
                        </button>
                    </div>
                </div>
            </div>
            <!-- Premium -->
            <div class="col-12 col-md-3">
                <div class="pkg-card featured p-4">
                    <span class="popular-badge">Most popular</span>
                    <p class="pkg-name mb-1">Premium</p>

                    <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">

                    <div class="price-val mb-0" data-monthly="@basicMonthlyPrice" data-annually="@basicannuallyPrice">
                        @if (billingType == "Annually")
                        {
                            @premiumannuallyPrice
                        }
                        else if (billingType == "Monthly")
                        {
                            @premiumMonthlyPrice
                        }
                        <span>/Month</span>
                    </div>
                    <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                    <ul class="feature-list mb-3">
                        <li><span class="check-dot check-teal"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Up to 25 Qualified Profile Views / Day</li>
                        <li><span class="check-dot check-teal"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Up to 750 Impressions / Day</li>

                    </ul>

                    <div class="mt-auto">
                        <button class="btn-pkg-primary" @onclick='@(() => OpenModal("Premium", "$39 – $79"))'>
                            Get Started
                        </button>
                    </div>
                </div>
            </div>
            <!-- Enterprise -->
            <div class="col-12 col-md-3">
                <div class="pkg-card p-4">
                    <p class="pkg-name mb-1">Enterprise</p>

                    <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                    <p class="price-val mb-0">Custom Pricing</p>
                    <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                    <ul class="feature-list mb-3">
                        <li><span class="check-dot check-purple"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Custom Qualified Profile Views</li>
                        <li><span class="check-dot check-purple"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Custom Impressions </li>
                    </ul>

                    <div class="mt-auto">
                        <button class="btn-pkg" @onclick='@(() => OpenModal("Enterprise", ""))'>
                            Get Started
                        </button>
                    </div>
                </div>
            </div>

        </div><!-- /row -->
        @*             <p class="text-center footer-note mt-4 mb-0">All plans include a 14-day free trial. No credit card required. Cancel anytime.</p>
 *@        </div><!-- /container -->
</section>


