        font-size: 0.85rem;
        font-weight: 500;
        padding: 9px;
        width: 100%;
        transition: background 0.15s;
    }

        .btn-pkg:hover {
            background: #f3f3f3;
        }

    .btn-pkg-primary {
        background: #534AB7;
        color: #EEEDFE;
        border: none;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        padding: 9px;
        width: 100%;
        transition: background 0.15s;
    }

        .btn-pkg-primary:hover {
