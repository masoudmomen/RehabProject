@page "/packages"
@using Rehab.EndPoint.Web.Components.Common
@using Rehab.EndPoint.Web.ViewModels
@rendermode InteractiveServer

<style>

</style>
 
    <section class="billing-toggle-wrap" aria-label="Billing options">
        
        <div class="billing-toggle">
            <input type="radio" id="billing-annual" name="billing" value="annual" 
             checked="@(billingType=="Annually")"
                   @onchange="@(() => OnBillingChanged("Annually"))" />
            <label for="billing-annual">Pay annually</label>

            <input type="radio" id="billing-monthly" name="billing" value="monthly"
                   checked="@(billingType == "Monthly")"
                   @onchange="@(() => OnBillingChanged("Monthly"))" />
            <label for="billing-monthly">Pay Monthly</label>
        </div>
    
    </section>
    <div class="text-center">
       <h2>Plans & Pricing </h2>
        @if (billingType == "Annually")
        {
            <p>
            Reduced monthly rate with a one-year commitment. All plans are billed monthly.
        </p>
        }
        else if (billingType == "Monthly")
        {
            <p>
            Flexible month-to-month billing. All plans are billed monthly.

            </p>
        }

    </div>

    <section class="packages mt-5">
        <!-- Pricing Cards -->
        <div class="container pb-2 px-4">
           
            <div class="row g-4">

                <!-- Free -->
                <div class="col-12 col-md-3">
                    <div class="pkg-card p-4">
                        <p class="pkg-name mb-1">Free</p>

                        <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                        <p class="price-val mb-0">$0</p>
                        <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">

                        <ul class="feature-list mb-3">
                            <li><span class="check-dot check-gray"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Basic Listing</li>
                            <li><span class="check-dot check-gray"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Minimal Visibility</li>

                        </ul>

                        <div class="mt-auto">
                            <button class="btn-pkg" @onclick='@(() => OpenModal("Free", "$0"))'>
                                Claim Profile
                            </button>
                        </div>
                    </div>
                </div>
                <!-- Basic -->
                <div class="col-12 col-md-3">
                    <div class="pkg-card p-4">
                        <p class="pkg-name mb-1">Basic</p>
                        <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                        <div class="price-val mb-0" data-monthly="$399" data-annually="$499">
                            @if (billingType == "Annually")
                            {
                                @basicannuallyPrice
                            }
                            else if (billingType == "Monthly")
                            {
                                @basicMonthlyPrice
                            }
                            <span>
                                /Month
                            </span>
                        </div>
                        <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                        <ul class="feature-list mb-3">
                            <li><span class="check-dot check-gray"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Up to 10 Qualified Profile Views / Day</li>
                            <li><span class="check-dot check-gray"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Up to 300 Impressions / Day</li>

                        </ul>

                        <div class="mt-auto">
                            <button class="btn-pkg" @onclick='@(() => OpenModal("Basic", "?????"))'>
                                Gest Started
                            </button>
                        </div>
                    </div>
                </div>
                <!-- Premium -->
                <div class="col-12 col-md-3">
                    <div class="pkg-card featured p-4">
                        <span class="popular-badge">Most popular</span>
                        <p class="pkg-name mb-1">Premium</p>

                        <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">

                        <div class="price-val mb-0" data-monthly="@basicMonthlyPrice" data-annually="@basicannuallyPrice">
                            @if (billingType == "Annually")
                            {
                                @premiumannuallyPrice
                             }else if(billingType == "Monthly")
                            {
                                @premiumMonthlyPrice
                            }
                            <span>/Month</span>
                        </div>
                        <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                        <ul class="feature-list mb-3">
                            <li><span class="check-dot check-teal"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Up to 25 Qualified Profile Views / Day</li>
                            <li><span class="check-dot check-teal"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Up to 750 Impressions / Day</li>

                        </ul>

                        <div class="mt-auto">
                            <button class="btn-pkg-primary" @onclick='@(() => OpenModal("Premium", "$39 – $79"))'>
                                Get Started
                            </button>
                        </div>
                    </div>
                </div>
                <!-- Enterprise -->
                <div class="col-12 col-md-3">
                    <div class="pkg-card p-4">
                        <p class="pkg-name mb-1">Enterprise</p>

                        <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                        <p class="price-val mb-0">Custom Pricing</p>
                        <hr class="my-2" style="border-color:#e8e7e0;opacity:1;">
                        <ul class="feature-list mb-3">
                            <li><span class="check-dot check-purple"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Custom Qualified Profile Views</li>
                            <li><span class="check-dot check-purple"><i class="fa-solid fa-check check-icon" aria-hidden="true"></i></span>Custom Impressions </li>
                        </ul>

                        <div class="mt-auto">
                            <button class="btn-pkg" @onclick='@(() => OpenModal("Enterprise", ""))'>
                                Get Started
                            </button>
                        </div>
                    </div>
                </div>

            </div><!-- /row -->

@*             <p class="text-center footer-note mt-4 mb-0">All plans include a 14-day free trial. No credit card required. Cancel anytime.</p>
 *@        </div><!-- /container -->
    </section>
  
    <section class="">
        <div class="container">
            <table class="comparison-table">
                <thead><tr><th>Feature</th><th>Basic</th><th>Premium</th><th>VIP</th></tr></thead>
                <tbody>
                    <tr><td>Directory Listing</td><td class="check">✓</td><td class="check">✓</td><td class="check">✓</td></tr>
                    <tr><td>Advanced Search with Full Filters</td><td class="dash">—</td><td class="check">✓</td><td class="check">✓</td></tr>
                    <tr><td>State Page Visibility</td><td class="dash">—</td><td class="check">✓</td><td class="check">✓</td></tr>
                    <tr><td>Category Page Visibility</td><td class="dash">—</td><td class="check">✓</td><td class="check">✓</td></tr>
                    <tr><td>Condition, Treatment, Insurance, Amenity, Level of Care, Who We Treat Categories</td><td class="dash">—</td><td class="check">✓</td><td class="check">✓</td></tr>
                    <tr><td>Enhanced Profile Detail &amp; Presentation</td><td class="dash">—</td><td class="check">✓</td><td class="check">✓</td></tr>
                    <tr><td>Full Profile Detail &amp; Presentation</td><td class="dash">—</td><td class="dash">—</td><td class="check">✓</td></tr>
                    <tr><td>Homepage / Top Search Placement</td><td class="dash">—</td><td class="dash">—</td><td class="check">✓</td></tr>
                    <tr><td>Popular Centers Section</td><td class="dash">—</td><td class="dash">—</td><td class="check">✓</td></tr>
                    <tr><td>Nearby Facilities Modal</td><td class="dash">—</td><td class="dash">—</td><td class="check">✓</td></tr>
                    <tr><td>Blog / Content Promotion</td><td class="dash">—</td><td class="dash">—</td><td class="check">✓</td></tr>
                </tbody>
            </table>
        </div>
    </section>
    <section class="claim-panel">
        <h2>It’s <span>free</span> to be listed</h2>
        <p>
            Search for your facility below. If your profile already exists, you can claim it.
            If it is not listed yet, submit your facility information and we will help you get started.
        </p>

        <div class="search-box">
            <input type="text" placeholder="Enter your facility name" />
            <button type="button">Search</button>
        </div>
    </section>
 


<PackagesModalComponent Visible="@showModal"
                        VisibleChanged="v => showModal = v"
                        PackageName="@selectedPackage"
                        PackagePrice="@selectedPrice" 
                        BillingType="@billingType"
                        />


@code {
    private bool showModal = false;
    private string selectedPackage;
    private string selectedPrice;
    private string paymentPeriod;

    private string billingType = "Annually";

    private string basicMonthlyPrice = "499";
    private string basicannuallyPrice = "399";

    private string premiumMonthlyPrice = "1,099";
    private string premiumannuallyPrice = "999";

    private string billingDescription = "Aannual plans include preferred pricing";

    private void OnBillingChanged(string value)
    {
        billingType = value;
    }

    void OpenModal(string package, string price)
    {
        selectedPackage = package;
        selectedPrice = price;
        showModal = true;
    }

    private async Task HandleSubmit(PackageRequestViewModel model)
    {
    }

}
<style>
    .hero-title {
        font-size: 2rem;
        font-weight: 500;
        color: #1a1a1a;
    }

    .hero-sub {
        font-size: 1rem;
        color: #6b6b6b;
    }

    .billing-toggle-wrap {
        display: flex;
        justify-content: center;
        margin: 0 auto 30px;
    }

    .billing-toggle {
        display: inline-flex;
        gap: 6px;
        background: #ffffff;
        border: 1px solid #dce6ef;
        border-radius: 999px;
        padding: 6px;
        box-shadow: 0 10px 28px rgba(18, 48, 74, .06);
    }

        .billing-toggle input {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }

        .billing-toggle label {
            cursor: pointer;
            border-radius: 999px;
            padding: 11px 18px;
            font-size: 14px;
            font-weight: 900;
            color: #607080;
            transition: .2s ease;
            white-space: nowrap;
        }

        .billing-toggle input:checked + label {
            background:var(--color-primary);
            color: #ffffff;
            box-shadow: 0 6px 16px rgba(44, 122, 155, .22);
        }
    /* ── Cards ── */
    .pkg-card {
        background: #ffffff;
        border: 1px solid #e0dfd8;
        border-radius: 14px;
        display: flex;
        flex-direction: column;
        height: 100%;
        position: relative;
    }

        .pkg-card.featured {
            border: 2px solid #7F77DD;
        }

    .pkg-name {
        font-size: 1.1rem;
        font-weight: 500;
    }

    .pkg-sub {
        font-size: 0.78rem;
        color: #6b6b6b;
    }

    .price-from {
        font-size: 0.65rem;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .price-val {
        font-size: 1.75rem;
        font-weight: 700;
        line-height: 1.2;
    }

        .price-val span {
            font-size: 1rem;
            color: #607080;
            font-weight: 500;
        }

    .price-range {
        font-size: 1rem;
        font-weight: 400;
        color: #6b6b6b;
    }

    .price-period {
        font-size: 0.75rem;
        color: #6b6b6b;
    }

    .section-label {
        font-size: 0.65rem;
        font-weight: 600;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.07em;
    }

    .feature-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

        .feature-list li {
            font-size: 0.78rem;
            color: #555;
            display: flex;
            align-items: flex-start;
            gap: 8px;
            line-height: 1.4;
        }

    .check-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .check-icon {
        color: #fff;
        font-size: 7px;
        line-height: 1;
    }

    .check-gray {
        background: #B4B2A9;
    }

    .check-teal {
        background: #5DCAA5;
    }

    .check-purple {
        background: #7F77DD;
    }

    /* ── Popular badge ── */
    .popular-badge {
        position: absolute;
        top: -13px;
        left: 50%;
        transform: translateX(-50%);
        white-space: nowrap;
        background: #EEEDFE;
        color: #3C3489;
        font-size: 0.7rem;
        font-weight: 500;
        padding: 3px 12px;
        border-radius: 6px;
    }

    /* ── CTA buttons ── */
    .btn-pkg {
        border: 1px solid #ccc;
        background: transparent;
        color: #1a1a1a;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        padding: 9px;
        width: 100%;
        transition: background 0.15s;
    }

        .btn-pkg:hover {
            background: #f3f3f3;
        }

    .btn-pkg-primary {
        background: #534AB7;
        color: #EEEDFE;
        border: none;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        padding: 9px;
        width: 100%;
        transition: background 0.15s;
    }

        .btn-pkg-primary:hover {
            background: #7F77DD;
            color: #fff;
        }

    /* ── Footer note ── */
    .footer-note {
        font-size: 0.72rem;
        color: #bbb;
    }

