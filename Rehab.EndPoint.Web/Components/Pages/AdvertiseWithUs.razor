@page "/advertise-with-us"
@using Rehab.EndPoint.Web.Components.Common
@using Rehab.Application.Email
@using Rehab.EndPoint.Web.ViewModels
@using Rehab.Application.Common
@using static Rehab.Application.Common.EmailTemplates
@inject IEmailService EmailService
@inject IConfiguration Config

<Seo Title="Advertise With Us - Rehab Navigator"
     Description="Advertise your rehabilitation facility on RehabNavigator. Explore provider advertising packages, featured placement options, and directory visibility plans to help more people find your treatment center."
     CanonicalUrl="https://Rehabnavigator.com/advertise-with-us"
     FaviconUrl="favicon.png" />
<main class="container py-5">

    <!-- ── Hero ── -->
    <section class="adv-hero bg-soft-blue rounded-4 p-5 text-center shadow-sm mb-4" aria-labelledby="advertise-title">
        <span class="badge-custome mb-3">Provider Advertising</span>
        <h1 id="advertise-title" class="display-5 fw-bold mt-2 mb-3" >Advertise With Us</h1>
        <p class="mx-auto fs-5" style="max-width:780px; color:var(--text-muted)">
            Help more people discover your treatment center through RehabNavigator's provider directory,
            search visibility, and facility profile opportunities.
        </p>
    </section>

    <!-- ── Plans link ── -->
    <section class="mb-4" aria-label="View Plans and Pricing">
        <a href="/packages" target="_blank" class="adv-plans-card bg-white rounded-4 p-4 shadow-sm d-flex">
            <span>View Plans &amp; Pricing</span>
            <span class="adv-plans-arrow">→</span>
        </a>
        <p class="text-center mt-2" style="font-size:14px; color:var(--text-muted)">
            Already listed on RehabNavigator?
            <a href="/claim-your-profile" target="_blank" class="fw-bold text-decoration-none" style="color:var(--adv-primary)">Claim your profile</a>.
        </p>
    </section>

    <!-- ── Contact form ── -->
    <section class="bg-white adv-card rounded-4 p-4 shadow-sm mb-4" aria-labelledby="contact-title">
        <div class="text-center mx-auto mb-4" style="max-width:720px">
            <h2 id="contact-title" class="fw-bold mb-2" style="color:var(--adv-dark)">Contact Our Team</h2>
            <p class="mb-0" style="color:var(--adv-muted)">
                Have a question about advertising options, provider visibility, facility listings, or profile placement?
                Share a few details and our team will contact you.
            </p>
        </div>

        <div style="max-width:820px" class="mx-auto">
            <div class="row g-3">
                 <EditForm Model="FormModel" OnValidSubmit="HandleSubmit" method="post" Enhance FormName="advertise-contact-form">
                    <DataAnnotationsValidator />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small" style="color:var(--adv-dark)">Facility Name *</label>
                            <InputText @bind-Value="FormModel.FacilityName" class="form-control" placeholder="Facility name" />
                            <ValidationMessage For="() => FormModel.FacilityName" class="text-danger small" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small" style="color:var(--adv-dark)">Contact Name *</label>
                            <InputText @bind-Value="FormModel.ContactName" class="form-control" placeholder="Your name" />
                            <ValidationMessage For="() => FormModel.ContactName" class="text-danger small" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small" style="color:var(--adv-dark)">Email *</label>
                            <InputText @bind-Value="FormModel.Email" class="form-control" placeholder="Email address" />
                            <ValidationMessage For="() => FormModel.Email" class="text-danger small" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small" style="color:var(--adv-dark)">What can we help you with?</label>
                            <InputSelect @bind-Value="FormModel.HelpTopic" class="form-select">
                                <option value="">Select one</option>
                                <option value="Advertising options">Advertising options</option>
                                <option value="Plans and pricing">Plans and pricing</option>
                                <option value="Multiple locations">Multiple locations</option>
                                <option value="Not sure yet">Not sure yet</option>
                            </InputSelect>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small" style="color:var(--adv-dark)">Message (Optional)</label>
                            <InputTextArea @bind-Value="FormModel.Message" class="form-control" rows="4" placeholder="Briefly tell us what you need." />
                        </div>
                        <div class="col-12">
                            @if (SuccessMessage is not null)
                            {
                                <div class="alert alert-success">@SuccessMessage</div>
                            }
                            @if (ErrorMessage is not null)
                            {
                                <div class="alert alert-danger">@ErrorMessage</div>
                            }
                            <button type="submit" class="btn btn-primary">Send Message</button>
                        </div>
                    </div>
                </EditForm>
            </div>

            <div class="rounded-3 p-3 mt-3" style="background:#f2f7fb; font-size:12px; color:var(--adv-muted)">
                By submitting this form, you agree to be contacted about your inquiry.
                Submitting this form does not automatically add your treatment center to RehabNavigator.
            </div>

            <button type="button" class="btn btn-primary w-100 mt-3">Contact Our Team</button>
        </div>
    </section>

    <!-- ── Why RehabNavigator ── -->
    <section class="mb-4" aria-labelledby="why-title">
        <div class="text-center mx-auto mb-4" style="max-width:780px">
            <h2 id="why-title" class="fw-bold mb-2" style="color:var(--adv-dark)">Why RehabNavigator?</h2>
            <p class="mb-0" style="color:var(--adv-muted)">
                RehabNavigator gives treatment providers a structured way to be seen in a directory environment
                where people compare rehab centers, detox services, addiction treatment programs, mental health providers,
                and behavioral health facilities.
            </p>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <article class="bg-white adv-card rounded-4 p-4 text-center shadow-sm h-100">
                    <div class="adv-icon mx-auto mb-3">⌕</div>
                    <h3 class="h5 fw-bold mb-2" style="color:var(--adv-dark)">Search Visibility</h3>
                    <p class="mb-0" style="color:var(--adv-muted); font-size:15px">
                        Help your facility appear through relevant directory searches, location pages, treatment filters,
                        level of care filters, and provider comparison paths.
                    </p>
                </article>
            </div>
            <div class="col-md-4">
                <article class="bg-white adv-card rounded-4 p-4 text-center shadow-sm h-100">
                    <div class="adv-icon mx-auto mb-3">✓</div>
                    <h3 class="h5 fw-bold mb-2" style="color:var(--adv-dark)">Clear Facility Information</h3>
                    <p class="mb-0" style="color:var(--adv-muted); font-size:15px">
                        Present your facility profile, website link, phone number, photos, highlights, treatment programs,
                        and provider information in a clear format.
                    </p>
                </article>
            </div>
            <div class="col-md-4">
                <article class="bg-white adv-card rounded-4 p-4 text-center shadow-sm h-100">
                    <div class="adv-icon mx-auto mb-3">↗</div>
                    <h3 class="h5 fw-bold mb-2" style="color:var(--adv-dark)">Provider Visibility Options</h3>
                    <p class="mb-0" style="color:var(--adv-muted); font-size:15px">
                        Choose advertising options designed to support directory visibility, estimated impressions,
                        qualified profile views, and featured placement opportunities.
                    </p>
                </article>
            </div>
        </div>
    </section>

    <!-- ── Placements ── -->
    <section class="bg-white adv-card rounded-4 p-4 shadow-sm mb-4" aria-labelledby="featured-title">
        <div class="text-center mx-auto mb-4" style="max-width:780px">
            <h2 id="featured-title" class="fw-bold mb-2" style="color:var(--adv-dark)">Where Will You Be Featured?</h2>
            <p class="mb-0" style="color:var(--adv-muted)">
                Depending on your selected provider advertising package, your treatment center may receive visibility
                across facility cards, provider profiles, relevant search results, filters, and featured content areas.
            </p>
        </div>

        <!-- placement items -->
        <article class="row align-items-center py-4 border-bottom g-3">
            <div class="col-md-12">
                <h3 class="h5 fw-bold mb-1" style="color:var(--adv-dark)">Treatment Center Cards</h3>
                <p class="mb-0" style="color:var(--adv-muted); font-size:15px">
                    Facility cards help users scan treatment centers in search results and compare basic provider information,
                    location, profile details, and next-step contact options.
                </p>
            </div>
           @*  <div class="col-md-4">
                <div class="adv-placement-preview">Facility Card Visibility</div>
            </div> *@
        </article>

        <article class="row align-items-center py-4 border-bottom g-3">
            <div class="col-md-12">
                <h3 class="h5 fw-bold mb-1" style="color:var(--adv-dark)">Facility Profile Pages</h3>
                <p class="mb-0" style="color:var(--adv-muted); font-size:15px">
                    Provider profiles can include facility details, phone number, website link, photos, highlights,
                    level of care, treatment programs, and other information submitted or verified for directory use.
                </p>
            </div>
         @*    <div class="col-md-4">
                <div class="adv-placement-preview">Profile Page Visibility</div>
            </div> *@
        </article>

        <article class="row align-items-center py-4 border-bottom g-3">
            <div class="col-md-12">
                <h3 class="h5 fw-bold mb-1" style="color:var(--adv-dark)">Relevant Searches &amp; Filters</h3>
                <p class="mb-0" style="color:var(--adv-muted); font-size:15px">
                    Paid visibility may support appearance across relevant searches and filters such as location,
                    conditions treated, treatment programs, level of care, amenities, and provider categories.
                </p>
            </div>
         @*    <div class="col-md-4">
                <div class="adv-placement-preview">Search &amp; Filter Visibility</div>
            </div> *@
        </article>

        <article class="row align-items-center py-4 g-3">
            <div class="col-md-12">
                <h3 class="h5 fw-bold mb-1" style="color:var(--adv-dark)">Featured Placement Opportunities</h3>
                <p class="mb-0" style="color:var(--adv-muted); font-size:15px">
                    Select packages may include featured search placement or featured content opportunities designed
                    to increase provider exposure within the RehabNavigator directory.
                </p>
            </div>
      @*       <div class="col-md-4">
                <div class="adv-placement-preview">Featured Placement</div>
            </div> *@
        </article>
    </section>

    <!-- ── Bottom CTA ── -->
    <section class="adv-bottom-cta rounded-4 p-5 text-center shadow " aria-label="Ready to Compare Plans">
        <h2 class="h3 fw-bold text-white mb-2">Ready to Compare Plans?</h2>
        <p class="mx-auto mb-4" style="max-width:660px; color:#d8e5ee">
            See available visibility options, profile features, and provider advertising packages.
        </p>
        <a href="/packages" target="_blank" class="btn btn-light fw-bold px-4 py-2 rounded-3">View Plans &amp; Pricing</a>
        <p class="mt-3 mb-0" style="font-size:14px; color:#d8e5ee">
            Already listed on RehabNavigator?
            <a href="/packages" target="_blank" class="text-white fw-bold">Claim your profile</a>.
        </p>
    </section>

</main>
@code{
    [SupplyParameterFromForm]
    private AdvertiseContactModel FormModel { get; set; } = new();

    private string? SuccessMessage;
    private string? ErrorMessage;
    private async Task HandleSubmit()
    {
        try
        {
            var adminEmail = Config["Email:ToAdmin"];
            var dto = new AdvertiseContactDto(
                    FormModel.FacilityName,
                    FormModel.ContactName,
                    FormModel.Email,
                    FormModel.HelpTopic,
                    FormModel.Message
                );
            await EmailService.SendEmailAsync(
                to: [adminEmail!],
                subject: "Contact Us | Advertise With Us",
                body:BuildContactUsEmailBody(dto)
                );
            await EmailService.SendEmailAsync(
                to: [FormModel.Email],
                subject: "We received your message – RehabNavigator",
                body: BuildAdvertiseContactConfirmationBody(FormModel.ContactName)
                );

            SuccessMessage = "Your message has been sent. We'll be in touch soon!";
            ErrorMessage = null;
            FormModel = new(); // reset
        }
        catch (Exception ex)
        {
            ErrorMessage = "Something went wrong. Please try again.";
            SuccessMessage = null;
        }
    }
  

}
 