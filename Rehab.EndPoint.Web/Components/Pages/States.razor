@page "/States/{statename}"
@rendermode InteractiveServer
@using Rehab.EndPoint.Web.ViewModels
@using Rehab.EndPoint.Web.Components.Common
@using Rehab.EndPoint.Web.Components.Facility
@using Rehab.EndPoint.Web.Data
@using Rehab.Application.Facilities

@inject IFacilityService FacilityService
@inject AutoMapper.IMapper mapper
@inject IJSRuntime JS

<div class="container  rounded-2 py-2">
    <BreadCrumbComponent Items="@breadCrumbItems"></BreadCrumbComponent>
</div>
<PageCover CustomImageUrl="@GetStateImagePath()"
           PageTitle=@("Recovery centers in " + statename) />
<div class="container mt-3">
    <div class="row">
        <div class="col-md-9">
            <SearchComponent searchTextFromComponent="@searchText" ApplySearchTextCallback="ApplySearch"></SearchComponent>

            @* report of filtering *@
            <div class="results-filters">
                <h5 class="mt-2">Filtered Items:</h5>


                @if (FullFacilityFilterItems.Conditions.Count > 0)
                {
                    <div class="filter-group">
                        <span class="filter-title">Condition:</span>
                        <div class="filter-items">
                            @foreach (var item in FullFacilityFilterItems.Conditions)
                            {
                                string tagId = "condition-" + item.Id.ToString();
                                <span class="filter-tag">
                                    @item.Name
                                    <button type="button" class="remove-button" aria-label="Remove filter"
                                            @onclick="() => {
                                            FullFacilityFilterItems.Conditions.Remove(item);
                                                Uncheck(tagId);}">
                                        ×
                                    </button>
                                </span>
                            }
                        </div>
                    </div>
                }

                @if (FullFacilityFilterItems.Treatments.Count > 0)
                {
                    <div class="filter-group">
                        <span class="filter-title">Treatment:</span>
                        <div class="filter-items">
                            @foreach (var item in FullFacilityFilterItems.Treatments)
                            {
                                string tagId = "treatment-" + item.Id.ToString();
                                <span class="filter-tag">
                                    @item.Name
                                    <button type="button" class="remove-button" aria-label="Remove filter"
                                            @onclick="() => { FullFacilityFilterItems.Treatments.Remove(item);
                                            Uncheck(tagId);}">
                                        ×
                                    </button>
                                </span>
                            }
                        </div>
                    </div>
                }


                @if (FullFacilityFilterItems.Wwts.Count > 0)
                {
                    <div class="filter-group">
                        <span class="filter-title">Who We Treat:</span>
                        <div class="filter-items">
                            @foreach (var item in FullFacilityFilterItems.Wwts)
                            {
                                string tagId = "wwt-" + item.Id.ToString();
                                <span class="filter-tag">
                                    @item.Name
                                    <button type="button" class="remove-button" aria-label="Remove filter"
                                            @onclick="() => { FullFacilityFilterItems.Wwts.Remove(item);
                                            Uncheck(tagId);}">
                                        ×
                                    </button>
                                </span>
                            }
                        </div>
                    </div>
                }

                @if (FullFacilityFilterItems.Locs.Count > 0)
                {
                    <div class="filter-group">
                        <span class="filter-title">Level of Care:</span>
                        <div class="filter-items">
                            @foreach (var item in FullFacilityFilterItems.Locs)
                            {
                                string tagId = "loc-" + item.Id.ToString();
                                <span class="filter-tag">
                                    @item.Name
                                    <button type="button" class="remove-button" aria-label="Remove filter"
                                            @onclick="() => { FullFacilityFilterItems.Locs.Remove(item);
                                            Uncheck(tagId);}">
                                        ×
                                    </button>
                                </span>
                            }
                        </div>
                    </div>
                }

                @if (FullFacilityFilterItems.Insurances.Count > 0)
                {
                    <div class="filter-group">
                        <span class="filter-title">Insurance:</span>
                        <div class="filter-items">
                            @foreach (var item in FullFacilityFilterItems.Insurances)
                            {
                                string tagId = "insurance-" + item.Id.ToString();
                                <span class="filter-tag">
                                    @item.Name
                                    <button type="button" class="remove-button" aria-label="Remove filter"
                                            @onclick="() => { FullFacilityFilterItems.Insurances.Remove(item);
                                            Uncheck(tagId);}">
                                        ×
                                    </button>
                                </span>
                            }
                        </div>
                    </div>
                }

                @if (FullFacilityFilterItems.Amenities.Count > 0)
                {
                    <div class="filter-group">
                        <span class="filter-title">Amenity:</span>
                        <div class="filter-items">
                            @foreach (var item in FullFacilityFilterItems.Amenities)
                            {
                                string tagId = "amenity-" + item.Id.ToString();
                                <span class="filter-tag">
                                    @item.Name
                                    <button type="button" class="remove-button" aria-label="Remove filter"
                                            @onclick="() => { FullFacilityFilterItems.Amenities.Remove(item);
                                            Uncheck(tagId);}">
                                        ×
                                    </button>
                                </span>
                            }
                        </div>
                    </div>
                }

                <button class="clear-filters" 
                        @onclick="() => { 
                            FullFacilityFilterItems = new();
                            FullFacilityFilterItems.States.Add(statename);
                            UnCheckAll();
                            searchText = string.Empty;
                            }">
                    Clear all
                </button>
            </div>
            
            <div class="container mt-3 mb-5 featured-centers ">
                <div class="d-md-none mb-3">
                    <div class="border border-1 px-3 rounded-3">
                        @* <FacilityFilter /> *@
                    </div>
                </div>
                <div class="d-flex align-items-center py-2" style="border-bottom: solid 2px #93e2f1;">
                    <h5 class=" mb-0">Our recovery centers in @statename</h5>
                </div>

                <div class="row g-4">
                    @foreach (var facility in FacilityCards)
                    {
                        <div class="col-md-4 mb-3">
                            <FacilityItem ShowTags="false" FacilityCard="facility" CustomClass="small-card" />
                        </div>
                    }
                </div>

                @if (IsLoading)
                {
                    <p>Loading...</p>
                }

                <div id="scrollTrigger"></div>
            </div>
        </div>
        <div class="col-md-3 d-md-block">
            <div class="border border-1 px-3 rounded-3 ">
                <FacilityFilter ApplyFilterCallback="ApplyFilter" FullFacilityFilterItems="FullFacilityFilterItems"  />
            </div>

        </div>
    </div>
</div>


@code {
    [Parameter]
    public string? statename { get; set; }   

    [Parameter]
    public string? searchText { get; set; }

    private List<BreadCrumbComponent.BreadCrumbItem> breadCrumbItems = new();
    public FacilityFilterItems FilteredItems { get; set; } = new();
    protected override void OnParametersSet()
    {
        breadCrumbItems = new()
        {
            new() {Text="Home" , Href="/"},
            new() {Text="States" , Href="/"},
            new() {Text= statename?? "Unknown" ,IsActive=true}

        };

    }
    private string GetStateImagePath()
    {
        if (string.IsNullOrWhiteSpace(statename))
        {
            return "img/statesimages/no-image.jpg";
        }

        var state = USStates.All.FirstOrDefault(s =>
            s.Name.Equals(statename, StringComparison.OrdinalIgnoreCase) ||
            s.UrlSlug.Equals(statename, StringComparison.OrdinalIgnoreCase));

        var imageFileName = state?.Image;

        if (string.IsNullOrWhiteSpace(imageFileName))
        {
            return "img/statesimages/no-image.jpg";
        }

        return $"img/statesimages/{imageFileName}";
    }
    private string GetStateDescription()
    {
        var stateLabel = string.IsNullOrWhiteSpace(statename) ? "this state" : statename;
        return $"Explore accredited recovery centers, resources, and support options across {stateLabel}.";
    }

    //infinite scroll
    //----------------------------------------------------------

    private List<FacilityCardViewmodel> FacilityCards = new();
    private int page = 1;
    private int pageSize = 12;
    private bool IsLoading = false;
    private bool HasMore = true;

    private DotNetObjectReference<States>? objRefState;

    [Parameter]
    public FullFacilityFilterItemsViewmodel FullFacilityFilterItems { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        FullFacilityFilterItems.States.Add(statename);

        //await LoadMore();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRefState = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("infiniteScroll.initialize",
                "scrollTrigger",
                objRefState);
        }
    }

    [JSInvokable]
    public async Task LoadMore()
    {
        if (IsLoading || !HasMore)
            return;

        IsLoading = true;
        StateHasChanged();

        var newItems = await FacilityService.GetFacilityCardsAsync(page, pageSize, "",
        mapper.Map<FullFacilityFilterItemsDto>(FullFacilityFilterItems));

        if (newItems.Item1.Count < pageSize)
            HasMore = false;

        FacilityCards.AddRange(mapper.Map<List<FacilityCardViewmodel>>(newItems.Item1));
        page++;

        IsLoading = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        objRefState?.Dispose();
    }


    //----------------------------------------------------------


    async Task ApplyFilter(FullFacilityFilterItemsViewmodel FullFacilityFilterItemsArg)
    {
        this.FullFacilityFilterItems = FullFacilityFilterItemsArg;
        FacilityCards = new();
        page = 1;
        IsLoading = false;
        HasMore = true;
        await LoadMore();
    }
    async Task ApplySearch(string searchTextFromComponent)
    {
        searchText = FullFacilityFilterItems.SearchText = searchTextFromComponent;
        await ApplyFilter(FullFacilityFilterItems);
    }




    private void Uncheck(string id)
    {
        HandleCheckbox(id, false);
    }
    

    private void HandleCheckbox(string id, bool state)
    {
         JS.InvokeVoidAsync("setCheckboxState", id, state);
    }

    private void UncheckState(string id)
    {
        HandleCheckboxState(id, false);
    }
    private void HandleCheckboxState(string id, bool state)
    {
         JS.InvokeVoidAsync("setCheckboxState", id, state);
    }

    private void UnCheckAll()
    {
         JS.InvokeVoidAsync("UnCheckAllCheckbox");
    }
}
