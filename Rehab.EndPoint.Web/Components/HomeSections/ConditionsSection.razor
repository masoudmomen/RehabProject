@using Rehab.EndPoint.Web.Components.Common
@using Rehab.EndPoint.Web.ViewModels
@using Rehab.EndPoint.Web.Data
@using Rehab.Application.Conditions
@using AutoMapper
@inject IMapper mapper
@inject Rehab.Application.Conditions.IConditionService ConditionService

<div class="container-fluid  bg-light-gray py-4">
    <div class="container my-5">
        <h2 class="section-title text-center mb-3">Find Specialized Care by Condition</h2>
        <p class="fs-5 text-center text-dark-subtle"> Targeted Care for Your Unique Journey to Wellness</p>
        <div class="row mb-3 justify-content-center align-items-stretch">
            @foreach (var card in ConditionCards )
            {
                <div class="col-12 col-md-3 mb-2 px-0 px-md-2">
                    <ConditionCardComponent Card="card" prefixImageURL="@serverUrl" />
                </div>
            }
        </div>
        <div class="row px-3 mb-4">
            <a class="border-gradient text-blue-dark text-center" target="_blank" href="/ConditionList">Visit All Treatments</a>
        </div>
    </div>
</div>
@code {
    [Inject] IConfiguration Config { get; set; } = default!;
    private string? serverUrl;
    public List<CardViewModel> ConditionCards = new();
    protected override void OnInitialized()
    {
        serverUrl = Config["AppSettings:AdminServerUrl"];
        ConditionCards = mapper.Map<List<CardViewModel>>(ConditionService.GetList().Take(4));
    }
}
 