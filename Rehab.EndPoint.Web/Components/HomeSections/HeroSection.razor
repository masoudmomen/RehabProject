@rendermode InteractiveServer
@inject NavigationManager NavigationManager
<section id="home" class="hero-section d-flex flex-column justify-content-center">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8 hero-content">
                <h1 class="hero-title mb-4">Find Drug and Alcohol Rehab Centers and Mental Health Treatment Providers</h1>
                <p class="hero-subtitle mb-5 px-5">RehabNavigator helps you find and compare drug and alcohol rehab centers, mental health treatment providers, detox, residential and outpatient programs, insurance information, facility information, and recovery resources in one place.</p>
            </div>
        </div>
    </div>
    <form @onsubmit="GoToFacilitiesPage" class="container-fluid d-flex justify-content-center mt-5">
        <div class="col-lg-8 hero-search-container">
            <div class="p-3 rounded-3">
                <div class="row mt-0 bg-white g-2 justify-content-center rounded-5">
                    <div class="col-md-4 rounded-5">
                        <input type="text"
                               class="form-control border-0 rounded-5 text-center"
                               @bind="state"
                               @bind:event="oninput"
                               placeholder="State"
                               list="statesList"
                               autocomplete="on"
                               spellcheck="true"
                               autocapitalize="words" />
                        <datalist id="statesList">
                            @foreach (var item in States)
                            {
                                <option value="@item" />
                            }
                        </datalist>
                    </div>

                    <div class="col-md-4 rounded-5">
                        <input type="text"
                               class="form-control border-0 rounded-5 text-center"
                               @bind="city"
                               @bind:event="oninput"
                               placeholder="City"
                               list="citiesList"
                               autocomplete="on"
                               spellcheck="true"
                               autocapitalize="words" />
                        <datalist id="citiesList">
                            @foreach (var item in Cities)
                            {
                                <option value="@item" />
                            }
                        </datalist>
                    </div>

                    <div class="col-md-4 rounded-5">
                        <input type="text"
                               class="form-control border-0 rounded-5 text-center"
                               @bind="condition"
                               @bind:event="oninput"
                               placeholder="Condition"
                               list="conditionsList"
                               autocomplete="on"
                               spellcheck="true"
                               autocapitalize="words" />
                        <datalist id="conditionsList">
                            @foreach (var item in Conditions)
                            {
                                <option value="@item" />
                            }
                        </datalist>
                    </div>
                </div>

                <div class="row justify-content-center">
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary-gradient btn-hero btn-lg rounded-5 w-100 mt-3">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            Find Treatment Centers
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>

</section>
