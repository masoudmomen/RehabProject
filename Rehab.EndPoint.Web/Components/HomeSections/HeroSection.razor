    @code {
        private string? state = string.Empty;
        private string? city = string.Empty;
        private string? condition = string.Empty;

        private List<string> query = new();
        private string url = "/facilities";

        // نمونه داده‌ها - در عمل می‌تواند از API/DB بیاید
        private List<string> States = new()
    {
        "California", "Texas", "Florida", "New York"
    };

        private List<string> Cities = new()
    {
        "Los Angeles", "Houston", "Miami", "New York"
    };

        private List<string> Conditions = new()
    {
        "Depression", "Anxiety", "Addiction", "PTSD"
    };

        private void GoToFacilitiesPage()
        {
            query.Clear();
            url = "/facilities";

            if (!string.IsNullOrWhiteSpace(state))
                query.Add($"state={Uri.EscapeDataString(state.Trim())}");

            if (!string.IsNullOrWhiteSpace(city))
                query.Add($"city={Uri.EscapeDataString(city.Trim())}");

            if (!string.IsNullOrWhiteSpace(condition))
                query.Add($"condition={Uri.EscapeDataString(condition.Trim())}");

            if (query.Any())
                url += "?" + string.Join("&", query);

            NavigationManager.NavigateTo(url);
        }
    }

}
