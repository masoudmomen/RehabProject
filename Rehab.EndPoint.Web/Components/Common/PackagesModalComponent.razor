@using Microsoft.AspNetCore.Components
@rendermode InteractiveServer
@using Rehab.Application.Email
@using Rehab.EndPoint.Web.ViewModels
@using Rehab.Application.Packages
@using AutoMapper
@inject IEmailService EmailService
@inject IConfiguration Config
@inject IPackageRequestService PackageService
@inject IMapper mapper
@if (Visible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-4">

                @if (!isSuccess)
                {
                    <!-- FORM VIEW -->
                    <div>
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <div>
                                <h5 class="modal-title fw-500 mb-0">Request access | @PackageName - @BillingType</h5>
                                <p class="text-muted mb-0" style="font-size:0.8rem;">
                                    Fill in your details and we'll send you a payment link
                                </p>
                            </div>
                            <button type="button" class="btn-close" @onclick="Close"></button>
                        </div>
                        @* <div class="mb-3 mt-3">
                            <span class="pkg-pill" id="pkgPill">@PackageName @PackagePrice</span>
                        </div> *@
                        <hr />
                        <EditForm Model="model" OnValidSubmit="SubmitAsync">
                            <DataAnnotationsValidator />
                            <ValidationSummary />
                            <h2> @PackageName</h2>
                            <div class="row g-2 mb-2">
                                
                                    <label class="form-label">First Name</label>
                                    <InputText class="form-control" @bind-value="model.FirstName" placeholder="Name" />
                              
                                @* <div class="col-6">
                                    <label class="form-label">Last Name</label>
                                    <InputText class="form-control" @bind-value="model.LastName" placeholder="Smith" />
                                </div> *@
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Email</label>
                                <InputText class="form-control" type="email" @bind-value="model.Email" placeholder="yourname@example.com" />
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Phone</label>
                                <input class="form-control" @bind-value="model.PhoneNumber" placeholder="+1 (555) 000-0000" />
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Facility Name</label>
                                <InputText class="form-control" @bind-value="model.CenterName" placeholder="Recovery Center Name" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Message</label>
                                <InputTextArea class="form-control" @bind-value="model.Message" placeholder="Tell us a bit about your center or any questions you have..."></InputTextArea>
                            </div>
                            <div class="info-box mb-3">
                                <div class="info-icon">i</div>
                                <p class="info-text">After submitting, our team will review your request and send a secure payment link to your email within 1 business day.</p>
                            </div>
                            <button class="btn-submit" type="submit" disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span>Sending...</span>
                                }
                                else
                                {
                                    <span>Submit request</span>
                                }
                            </button>
                        </EditForm>
                    </div>

                }
                else
                {
                    <!-- SUCCESS VIEW -->
                    <div class="text-center py-3">
                        <div class="success-icon"></div>

                        <h5 class="fw-500 mb-2">Request received!</h5>

                        <p class="text-muted mb-4" style="font-size:0.85rem;">
                            Thank you for your interest in <strong>@PackageName</strong><br />
                            We will contact you soon.
                        </p>

                        <button class="btn-pkg" @onclick="Close">
                            Close
                        </button>
                    </div>
                }

            </div>
        </div>
    </div>
}
@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    [Parameter] public string PackageName { get; set; }
    [Parameter] public string PackagePrice { get; set; }
    [Parameter] public string BillingType { get; set; }

    // [Parameter] public EventCallback<PackageRequestViewModel> OnSubmit { get; set; }

    private PackageRequestViewModel model = new();
    private bool isLoading = false;
    private bool isSuccess = false;

    private async Task SubmitAsync()
    {
        isLoading = true;
        model.PackageType = NormalizePackageType(PackageName);
        model.BillingType = NormalizePackageType(BillingType);
        string admin = Config["Email:ToAdmin"];
        if (string.IsNullOrWhiteSpace(model.FirstName) ||
            string.IsNullOrWhiteSpace(model.LastName) ||
            string.IsNullOrWhiteSpace(model.Email))
        {
         
            isLoading = false;
            return;
        }

        var requestDto = mapper.Map<PackageRequestDto>(model);
        var addResult = PackageService.Add(requestDto);
        if (!addResult.Success)
        {
            isLoading = false;
            return;
        }
        // if (OnSubmit.HasDelegate)
        //     await OnSubmit.InvokeAsync(model);

        if (!string.IsNullOrWhiteSpace(admin))
        {
            await EmailService.SendEmailAsync(
                to: [admin,"masoudmomen@hotmail.com","maryam.s.nabavi@gmail.com"],
                subject: "New Package Request",
                body: BuildEmailBody(model.FirstName, model.LastName, PackageName, model.PhoneNumber, model.Email, model.CenterName, model.Message,model.BillingType)
            );
            await EmailService.SendEmailAsync(
                to: [model.Email,"masoudmomen@hotmail.com","maryam.s.nabavi@gmail.com"],
                subject: "Your Package Request Has Been Received – RehabNavigator",
                body: BuildUserConfirmationEmailBody(model.FirstName, model.LastName, PackageName, model.BillingType, model.CenterName)
            );
        }

        isLoading = false;
        isSuccess = true;
    }

    private static string NormalizePackageType(string packageName)
    {
        return packageName switch
        {
            "Premium+" => "PremiumPlus",
            _ => packageName
        };
    }

    private string BuildEmailBody(string fname, string lName, string packageName, string phone, string email, string centerName, string message,string billingType)
    {
        return $@"
            <h2>New Package Request</h2>
            <p><strong>Name:</strong> {fname}  {lName} </p>
            <p><strong>Package:</strong> {packageName}</p>
            <p><strong>Billing Type:</strong> {billingType}</p>
            <p><strong>Center name:</strong> {centerName}</p>
            <p><strong>Phone:</strong> {phone}</p>
            <p><strong>Email:</strong> {email}</p>
            <p><strong>Message:</strong> {message}</p>
            <p><strong>Date:</strong> {DateTime.UtcNow}</p>
        ";
    }
    private string BuildUserConfirmationEmailBody(string fname, string lName, string packageName, string billingType, string centerName)
    {
        return $@"
        <div style='font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;'>

            <h2 style='color: #4a6fa5;'>Your Package Request Has Been Submitted</h2>

            <p>Dear {fname} {lName},</p>

            <p>Thank you for your interest! Your package request has been successfully submitted.
            Our team will review your request and contact you shortly.</p>

            <div style='background-color: #f5f7fa; border-left: 4px solid #4a6fa5; padding: 15px; margin: 20px 0;'>
                <h3 style='margin-top: 0;'>Request Summary</h3>
                <p><strong>Package:</strong> {packageName}</p>
                <p><strong>Billing Type:</strong> {billingType}</p>
                <p><strong>Center Name:</strong> {centerName}</p>
                <p><strong>Submitted At:</strong> {DateTime.UtcNow:MMMM dd, yyyy HH:mm} UTC</p>
            </div>

            <p>If you need assistance in the meantime, feel free to reach out to our support team:</p>

            <p>
                <a href='https://www.rehabnavigator.com/contact-us'
                   style='display: inline-block; background-color: #4a6fa5; color: white;
                          padding: 10px 20px; text-decoration: none; border-radius: 5px;'>
                    Contact Support
                </a>
            </p>

            <p style='color: #888; font-size: 0.9em; margin-top: 30px;'>
                This is an automated confirmation email. Please do not reply to this message.
            </p>

        </div>
    ";
    }
    private async Task Close()
    {
        isSuccess = false;
        model = new();

        await VisibleChanged.InvokeAsync(false);
    }

}
 