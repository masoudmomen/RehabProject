@page "/blogtopic/add"
@using Rehab.Application.Blog
@using Rehab.EndPoint.AdminPanel.Viewmodels
@inject Rehab.Application.Blog.IBlogTopicService BlogTopicService
@inject AutoMapper.IMapper mapper
@rendermode InteractiveServer
@inject AlertService AlertService
@inject IWebHostEnvironment Env
@inject IImageUploaderService Uploader

<div class="w-75 mx-auto p-4">
    <h3>Add BlogTopic</h3>

    <EditForm Model="BlogTopic" OnValidSubmit="Add" class="form-control" FormName="AddBlogTopicForm">
        <DataAnnotationsValidator></DataAnnotationsValidator>
        <ValidationSummary class="text-danger" />
        <label>Name</label>
        <InputText @bind-Value="BlogTopic.Name" class="form-control my-2"></InputText>
        <label>Icon</label>
        <InputFile OnChange="HandleSelected" class="form-control my-2" accept="image/*" />
        <label>Description</label>
        <InputTextArea @bind-Value="BlogTopic.Description" class="form-control my-2"></InputTextArea>
        @if (isAddBtnActive)
        {
            <button class="btn btn-primary my-2">Add</button>
        }
        else
        {
            <button class="btn btn-outline-danger my-2" disabled>Add</button>
        }

    </EditForm>
</div>

@code {
    public BlogPostTopicViewModel BlogTopic { get; set; } = new();
    public ResultViewmodel<BlogPostTopicViewModel> Result { get; set; } = new();
    private bool isAddBtnActive = true;

    private async Task Add()
    {
        if (BlogTopic is not null)
        {
            if (UploadedPaths.Count > 0)
            {
                BlogTopic.Logo = UploadedPaths[0];
            }
            else
            {
                BlogTopic.Logo = "";
            }

            var BlogTopicDto = mapper.Map<BlogTopicDto>(BlogTopic);
            BaseDto<BlogTopicDto> result = BlogTopicService.Add(BlogTopicDto);
            Result = mapper.Map<ResultViewmodel<BlogPostTopicViewModel>>(result);
            if (Result.Success)
            {
                BlogTopic = new();
                UploadedPaths.Clear();
            }
            await AlertService.ShowAsync(Result.Message, Result.Status);
        }
    }

    List<string> UploadedPaths = new();

    private async Task HandleSelected(InputFileChangeEventArgs e)
    {
        isAddBtnActive = false;
        StateHasChanged();
        var files = e.GetMultipleFiles();
        var paths = await Uploader.UploadAsync(files, Env.WebRootPath, "uploads/BlogTopics");
        UploadedPaths.Clear();
        UploadedPaths.AddRange(paths);
        if (UploadedPaths.Count > 0)
        {
            isAddBtnActive = true;
        }
    }
}
