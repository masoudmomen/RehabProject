@page "/blogtag/add"

@using Rehab.Application.Blog
@using Rehab.EndPoint.AdminPanel.Viewmodels
@inject Rehab.Application.Blog.IBlogTagService BlogTagService
@inject AutoMapper.IMapper mapper
@rendermode InteractiveServer
@inject AlertService AlertService
@inject IWebHostEnvironment Env
@inject IImageUploaderService Uploader
 

<div class="w-75 mx-auto p-4">
    <h3>Add BlogTag</h3>

    <EditForm Model="BlogTag" OnValidSubmit="Add" class="form-control" FormName="AddBlogTagForm">
        <DataAnnotationsValidator></DataAnnotationsValidator>
        <ValidationSummary class="text-danger" />
        <label>Name</label>
        <InputText @bind-Value="BlogTag.Name" class="form-control my-2"></InputText>
        <label>Icon</label>
        <InputFile OnChange="HandleSelected" class="form-control my-2" accept="image/*" />
        <label>Description</label>
        <InputTextArea @bind-Value="BlogTag.Description" class="form-control my-2"></InputTextArea>
        @if (isAddBtnActive)
        {
            <button class="btn btn-primary my-2">Add</button>
        }
        else
        {
            <button class="btn btn-outline-danger my-2" disabled>Add</button>
        }

    </EditForm>
</div>

@code {
    public BlogPostTagViewModel BlogTag { get; set; } = new();
    public ResultViewmodel<BlogPostTagViewModel> Result { get; set; } = new();
    private bool isAddBtnActive = true;

    private async Task Add()
    {
        if (BlogTag is not null)
        {
            if (UploadedPaths.Count > 0)
            {
                BlogTag.Logo = UploadedPaths[0];
            }
            else
            {
                BlogTag.Logo = "";
            }

            var BlogTagDto = mapper.Map<BlogTagDto>(BlogTag);
            BaseDto<BlogTagDto> result = BlogTagService.Add(BlogTagDto);
            Result = mapper.Map<ResultViewmodel<BlogPostTagViewModel>>(result);
            if (Result.Success)
            {
                BlogTag = new();
                UploadedPaths.Clear();
            }
            await AlertService.ShowAsync(Result.Message, Result.Status);
        }
    }

    List<string> UploadedPaths = new();

    private async Task HandleSelected(InputFileChangeEventArgs e)
    {
        isAddBtnActive = false;
        StateHasChanged();
        var files = e.GetMultipleFiles();
        var paths = await Uploader.UploadAsync(files, Env.WebRootPath, "uploads/BlogTags");
        UploadedPaths.Clear();
        UploadedPaths.AddRange(paths);
        if (UploadedPaths.Count > 0)
        {
            isAddBtnActive = true;
        }
    }
}
